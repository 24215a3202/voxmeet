# ============================================
# VoxMeet Environment Variables
# Copy to .env and fill in values
# ============================================

# --- Frontend (apps/web/.env.local) ---
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server (apps/server/.env) ---
PORT=3001
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://user:password@localhost:5432/voxmeet

# Admin
ADMIN_SECRET=change-me-to-a-long-random-string
ADMIN_JWT_SECRET=change-me-another-long-random-string

# CORS
ALLOWED_ORIGIN=http://localhost:3000

# TURN Server
TURN_URL=turn:turn.example.com:3478
TURN_USERNAME=
TURN_CREDENTIAL=
TURN_REST_API_KEY=

# Security
IP_HASH_SALT=change-me-to-a-cryptographic-salt
LOG_LEVEL=info
